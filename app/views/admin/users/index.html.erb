<div class="mx-auto md:w-2/3 w-full">
  <h1 class="font-bold text-4xl mb-8">All Users</h1>

  <div class="bg-white border rounded-lg overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Role</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Company</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Joined</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @users.each do |user| %>
          <tr>
            <td class="px-6 py-4 text-sm text-gray-900"><%= user.email_address %></td>
            <td class="px-6 py-4 text-sm text-gray-600"><%= user.role.capitalize %></td>
            <td class="px-6 py-4 text-sm text-gray-600"><%= user.company.name %></td>
            <td class="px-6 py-4 text-sm text-gray-400"><%= user.created_at.strftime("%b %d, %Y") %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

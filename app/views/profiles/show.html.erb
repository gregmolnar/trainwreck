<div class="mx-auto md:w-2/3 w-full">
  <h1 class="font-bold text-4xl mb-8">My Profile</h1>

  <div class="bg-white border rounded-lg p-6 space-y-4">
    <div>
      <h2 class="text-sm font-medium text-gray-500">Email</h2>
      <p class="text-gray-800 mt-1"><%= @user.email_address %></p>
    </div>

    <div>
      <h2 class="text-sm font-medium text-gray-500">Role</h2>
      <p class="text-gray-800 mt-1"><%= @user.role.capitalize %></p>
    </div>

    <div>
      <h2 class="text-sm font-medium text-gray-500">Company</h2>
      <p class="text-gray-800 mt-1"><%= @user.company.name %></p>
    </div>

    <div class="border-t pt-4">
      <h2 class="text-sm font-medium text-gray-500">API Key</h2>
      <p class="mt-1 font-mono text-sm bg-gray-50 border rounded px-3 py-2 break-all">
        <%= @user.api_key || "No API key generated yet" %>
      </p>
      <p class="text-xs text-gray-400 mt-1">This key provides full API access to your account.</p>
      <% if @user.api_key %>
        <div class="mt-3">
          <p class="text-xs font-medium text-gray-500 mb-1">Example usage:</p>
          <pre class="font-mono text-xs bg-gray-900 text-green-400 rounded px-3 py-2 overflow-x-auto whitespace-pre-wrap">curl -H "Authorization: Bearer <%= @user.api_key %>" <%= request.base_url %>/api/documents
curl -H "Authorization: Bearer <%= @user.api_key %>" <%= request.base_url %>/api/documents/:id</pre>
        </div>
      <% end %>
    </div>

    <div>
      <h2 class="text-sm font-medium text-gray-500">Member Since</h2>
      <p class="text-gray-800 mt-1"><%= @user.created_at.strftime("%B %d, %Y") %></p>
    </div>

    <div class="pt-4">
      <%= link_to "Edit Profile", edit_profile_path, class: "rounded-lg py-2 px-4 bg-blue-600 text-white text-sm font-medium hover:bg-blue-700" %>
    </div>
  </div>
</div>

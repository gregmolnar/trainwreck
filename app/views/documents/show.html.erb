<div class="mx-auto md:w-2/3 w-full">
  <h1 class="font-bold text-4xl mb-8"><%= @document.title %></h1>

  <div class="bg-white border rounded-lg p-6">
    <div class="mb-4">
      <h2 class="text-lg font-semibold text-gray-700">Description</h2>
      <p class="text-gray-600 mt-1"><%= @document.description %></p>
    </div>

    <div class="mb-4">
      <h2 class="text-lg font-semibold text-gray-700">External URL</h2>
      <% if @document.external_url.present? %>
        <p class="text-gray-600 mt-1"><%= link_to @document.external_url, @document.external_url, target: "_blank", class: "text-blue-600 hover:underline" %></p>
      <% else %>
        <p class="text-gray-400 mt-1 italic">No external URL provided</p>
      <% end %>
    </div>

    <div class="mb-4">
      <h2 class="text-lg font-semibold text-gray-700">Company</h2>
      <p class="text-gray-600 mt-1"><%= @document.company.name %></p>
    </div>

    <% if @document.uploader %>
      <div class="mb-4">
        <h2 class="text-lg font-semibold text-gray-700">Uploaded By</h2>
        <p class="text-gray-600 mt-1"><%= @document.uploader.email_address %></p>
      </div>
    <% end %>

    <% if @document.file.attached? %>
      <div class="mb-4">
        <h2 class="text-lg font-semibold text-gray-700">Attached File</h2>
        <p class="text-gray-600 mt-1">
          <%= link_to @document.file.filename, url_for(@document.file), target: "_blank", class: "text-blue-600 hover:underline" %>
          (<%= number_to_human_size(@document.file.byte_size) %>)
        </p>
      </div>
    <% end %>

    <div class="flex space-x-4 mt-8">
      <%= link_to "Edit", edit_document_path(@document), class: "rounded-lg py-3 px-5 bg-gray-100 text-gray-700 font-medium hover:bg-gray-200" %>
      <%= link_to "Back to documents", documents_path, class: "rounded-lg py-3 px-5 bg-gray-100 text-gray-700 font-medium hover:bg-gray-200" %>
      <%= link_to "Delete", @document, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "rounded-lg py-3 px-5 bg-red-100 text-red-700 font-medium hover:bg-red-200" %>
    </div>
  </div>
</div>

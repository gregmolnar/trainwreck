<div class="mx-auto md:w-2/3 w-full">
  <h1 class="font-bold text-4xl mb-8">Edit Document</h1>

  <%= form_with model: @document, class: "space-y-6" do |form| %>
    <% if @document.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded-lg p-4">
        <h2 class="text-red-800 font-semibold mb-2"><%= pluralize(@document.errors.count, "error") %> prohibited this document from being saved:</h2>
        <ul class="list-disc list-inside text-red-700">
          <% @document.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= form.label :title, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :title, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
    </div>

    <div>
      <%= form.label :description, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_area :description, rows: 4, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
    </div>

    <div>
      <%= form.label :external_url, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :external_url, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
    </div>

    <div>
      <%= form.label :company_id, class: "block text-sm font-medium text-gray-700" %>
      <%= form.collection_select :company_id, Company.all, :id, :name, {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
    </div>

    <div>
      <%= form.label :file, class: "block text-sm font-medium text-gray-700" %>
      <% if @document.file.attached? %>
        <p class="text-sm text-gray-600 mb-2">Current file: <%= @document.file.filename %></p>
      <% end %>
      <%= form.file_field :file, class: "mt-1 block w-full" %>
    </div>

    <div class="flex space-x-4">
      <%= form.submit "Update Document", class: "rounded-lg py-3 px-5 bg-blue-600 text-white font-medium cursor-pointer" %>
      <%= link_to "Cancel", @document, class: "rounded-lg py-3 px-5 bg-gray-100 text-gray-700 font-medium hover:bg-gray-200" %>
    </div>
  <% end %>
</div>

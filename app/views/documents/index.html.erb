<div class="mx-auto md:w-2/3 w-full">
  <div class="flex justify-between items-center mb-8">
    <h1 class="font-bold text-4xl">Documents</h1>
    <%= link_to "New document", new_document_path, class: "rounded-lg py-3 px-5 bg-blue-600 text-white font-medium" %>
  </div>

  <div class="space-y-4">
    <% @documents.each do |document| %>
      <div class="border rounded-lg p-4 hover:bg-gray-50">
        <div class="flex justify-between items-start">
          <div>
            <h2 class="text-xl font-semibold"><%= link_to document.title, document, class: "text-blue-600 hover:underline" %></h2>
            <p class="text-gray-600 mt-1"><%= truncate(document.description, length: 100) %></p>
            <p class="text-sm text-gray-500 mt-2">Company: <%= document.company.name %></p>
          </div>
          <div class="flex space-x-2">
            <%= link_to "Edit", edit_document_path(document), class: "text-blue-600 hover:underline" %>
            <%= link_to "Delete", document, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "text-red-600 hover:underline" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
